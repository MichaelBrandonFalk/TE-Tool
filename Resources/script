#################################
# Phase 2 – True Peaks  (original WAV-split method)
#################################
step_start "Phase 2 TruePeaks"
ts_phase=$(date +%s)

# ---- temp workspace ------------------------------------------------
TP_WD=$(mktemp -d /tmp/truepeak.XXXXXX)
trap 'rm -rf "$TP_WD"' RETURN

stereo_wav="$TP_WD/stereo.wav"
left_wav="$TP_WD/left.wav"
right_wav="$TP_WD/right.wav"
left_log="$TP_WD/left_tp.txt"
right_log="$TP_WD/right_tp.txt"

# ---- 1) extract stereo PCM -----------------------------------------

"$FFMPEG_BIN" -hide_banner -nostats -i "$FILE" -map 0:a:0 -c:a pcm_s24le -y "$stereo_wav" > /dev/null 2>&1


# ---- 2) split to mono legs -----------------------------------------
"$FFMPEG_BIN" -hide_banner -nostats -i "$stereo_wav" \
  -af "pan=mono|c0=FL" -c:a pcm_s24le -y "$left_wav" > /dev/null 2>&1

"$FFMPEG_BIN" -hide_banner -nostats -i "$stereo_wav" \
  -af "pan=mono|c0=FR" -c:a pcm_s24le -y "$right_wav" > /dev/null 2>&1


# ---- 3) loudnorm on each leg in parallel ---------------------------
scan_tp () {          # $1 wav file  $2 stderr log
  "$FFMPEG_BIN" -hide_banner -nostats -i "$1" \
    -af "loudnorm=I=-24:LRA=7:TP=-1.5:print_format=summary" \
    -f null - > /dev/null 2> "$2"
}

scan_tp "$left_wav"  "$left_log"  &
scan_tp "$right_wav" "$right_log" &
wait

# ---- 4) pull “Input True Peak” (dBTP, numeric) ---------------------
get_tp () { grep -m1 "Input True Peak" "$1" | awk '{print $(NF-1)}'; }

left_tp=$( get_tp "$left_log" )
right_tp=$( get_tp "$right_log" )

# ---- 5) verdict helper  (±0.03 dB “close” window) ------------------
judge_tp () {
  local tp=$1
  if [[ -z "$tp" || "$tp" == "-inf" ]]; then
       echo "⚠️  Unable to measure – check in Audition"
  elif (( $(echo "$tp <= -2.5" | bc -l) )); then
       echo "✅ PASS ($tp dBTP)"
  elif (( $(echo "$tp <= -1.5" | bc -l) )); then
       echo "🟡 Close (-2 dBTP ±0.5) – verify in Audition ($tp dBTP)"
  else
       echo "❌ FAIL ($tp dBTP)"
  fi
}

LEFT_TP_RESULT=$(judge_tp  "$left_tp")
RIGHT_TP_RESULT=$(judge_tp "$right_tp")




step_end "Phase 2 TruePeaks"

