check_total_run_time() {
  local total_frames=""
  local duration_sec=""
  local tc_out=""

  # Try ExifTool first (most accurate if markers/exported from Premiere)
  total_frames=$("$EXIFTOOL_BIN" -s -s -s -VideoFrameCount "$FILE")
  if [[ -z "$total_frames" ]]; then
    # Fallback: FFprobe frame count for video stream 0
    total_frames=$("$FFPROBE_BIN" -v error -select_streams v:0 \
      -show_entries stream=nb_frames \
      -of default=noprint_wrappers=1:nokey=1 "$FILE")
  fi

  # Fallback for missing/empty
  if [[ -z "$total_frames" || "$total_frames" == "N/A" ]]; then
    # Fallback to duration in seconds
    duration_sec=$("$FFPROBE_BIN" -v error -select_streams v:0 \
      -show_entries stream=duration \
      -of default=noprint_wrappers=1:nokey=1 "$FILE" | awk '{print int($1)}')
    # Assume 29.97 for timecode calc
    total_frames=$((duration_sec * 30))
  else
    duration_sec=$((total_frames / 30))
  fi

  # Drop-frame converter (copy from above)
  frames_to_dropframe() {
    local frames=$1
    local fps=30
    local d=2
    local total_minutes=$((frames / (fps * 60)))
    local drop_frames=$((d * (total_minutes - (total_minutes / 10))))
    local tc_frames=$((frames + drop_frames))
    local hh=$((tc_frames / (fps * 60 * 60)))
    local mm=$(( (tc_frames / (fps * 60)) % 60 ))
    local ss=$(( (tc_frames / fps) % 60 ))
    local ff=$((tc_frames % fps))
    printf "%02d:%02d:%02d;%02d" "$hh" "$mm" "$ss" "$ff"
  }

  tc_out=$(frames_to_dropframe "$total_frames")

  # Final pretty output
  if [[ -n "$total_frames" && "$total_frames" != "N/A" ]]; then
    TOTAL_RUN_TIME_RESULT="Total Runtime: $tc_out "
  else
    TOTAL_RUN_TIME_RESULT="Unable to determine total runtime"
  fi
}







