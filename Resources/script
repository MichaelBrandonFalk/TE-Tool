check_dynamic_stereo() {

###
### Dynamic Stereo


step_start "Phase 2 Dynamic Stereo Test"

win_len=5
rms_values=()
best_diff_db=""
best_label=""
best_dir_label=""

if [[ "$channel_layout" != "stereo" ]]; then
  dbg "DEBUG: non-stereo layout, skipping RMS test"
  DYNAMIC_STEREO_RESULT="⚠️  N A (layout: $channel_layout)"
else
  # Get full duration in seconds
  duration_sec=$(
    "$FFPROBE_BIN" -v error -show_entries format=duration \
    -of default=noprint_wrappers=1:nokey=1 "$FILE" |
    awk '{print int($1)}'
  )


  # Build fractional offsets: 0%, 25%, 50%, 75%
  offsets=()
  for frac in 0 25 50 75; do
    off=$(( duration_sec * frac / 100 ))
    (( off + win_len > duration_sec )) && off=$(( duration_sec - win_len - 1 ))
    (( off < 0 )) && off=0
    offsets+=("$off")
  done
  # Deduplicate and sort
  offsets=($(printf '%s\n' "${offsets[@]}" | sort -n | uniq))

  for offset in "${offsets[@]}"; do
    cmd=( "$FFMPEG_BIN" -hide_banner -nostats -ss "$offset" -t "$win_len" \
          -i "$FILE" -map 0:a:0 -vn \
          -af "pan=mono|c0=0.5*c0 - 0.5*c1,astats=metadata=1:reset=1,\
               ametadata=print:key=lavfi.astats.Overall.RMS_level:file=-" \
          -f null - )

    rms_sample=$("${cmd[@]}" 2>&1 \
                | grep "lavfi.astats.Overall.RMS_level" \
                | tail -1 \
                | cut -d= -f2 \
                | tr -d ' ')

    # Also measure per-channel RMS in the same window for a human-friendly balance label
    left_rms=$( "$FFMPEG_BIN" -hide_banner -nostats -ss "$offset" -t "$win_len" \
                 -i "$FILE" -map 0:a:0 -vn \
                 -af "pan=mono|c0=FL,astats=metadata=1:reset=1,ametadata=print:key=lavfi.astats.Overall.RMS_level:file=-" \
                 -f null - 2>&1 \
               | grep "lavfi.astats.Overall.RMS_level" | tail -1 | cut -d= -f2 | tr -d ' ' )
    right_rms=$( "$FFMPEG_BIN" -hide_banner -nostats -ss "$offset" -t "$win_len" \
                  -i "$FILE" -map 0:a:0 -vn \
                  -af "pan=mono|c0=FR,astats=metadata=1:reset=1,ametadata=print:key=lavfi.astats.Overall.RMS_level:file=-" \
                  -f null - 2>&1 \
                | grep "lavfi.astats.Overall.RMS_level" | tail -1 | cut -d= -f2 | tr -d ' ' )

    # Validate and compute channel imbalance (absolute difference)
    if [[ -n "$left_rms" && -n "$right_rms" && "$left_rms" != "nan" && "$right_rms" != "nan" && "$left_rms" != "-inf" && "$right_rms" != "-inf" ]]; then
      # Convert to numeric with awk and compute |L - R|
      diff_db=$( awk -v L="$left_rms" -v R="$right_rms" 'BEGIN{d=L-R; if(d<0)d=-d; printf "%.1f", d}' )
      # Direction label
      dir_label=$( awk -v L="$left_rms" -v R="$right_rms" 'BEGIN{if(L+0 < R+0) print "Left quieter"; else if(R+0 < L+0) print "Right quieter"; else print "Balanced"}' )
      # Qualifier based on magnitude
      qual=$( awk -v d="$diff_db" 'BEGIN{ if(d <= 3.0) print "balanced"; else if(d <= 15.0) print "slightly"; else print "much" }' )

      # Direction-only human label used for concise output
      if [[ "$dir_label" == "Balanced" ]]; then
        human_dir_label="Balanced"
      else
        human_dir_label=$( echo "$dir_label" | awk -v q="$qual" '{gsub(/quieter$/, q" quieter"); print}' )
      fi
      # Build human label (e.g., "~46.0 dB, Left much quieter")
      human_label="$diff_db dB, $dir_label"
      if [[ "$dir_label" == "Balanced" ]]; then
        human_label="$diff_db dB, Balanced"
      else
        # insert qualifier if not balanced
        human_label=$( echo "$human_label" | awk -v q="$qual" '{gsub(/quieter$/, q" quieter"); print}' )
      fi

      # Keep the worst-case channel difference for reporting
      if [[ -z "$best_diff_db" ]]; then
        best_diff_db="$diff_db"; best_label="$human_label"; best_dir_label="$human_dir_label"
      else
        is_greater=$( awk -v a="$diff_db" -v b="$best_diff_db" 'BEGIN{print (a>b)?1:0}' )
        if [[ "$is_greater" -eq 1 ]]; then
          best_diff_db="$diff_db"; best_label="$human_label"; best_dir_label="$human_dir_label"
        fi
      fi
    fi

    if [[ -n "$rms_sample" && "$rms_sample" != "nan" && "$rms_sample" != "-inf" ]]; then
      rms_values+=("$rms_sample")
    else
      dbg "DEBUG:   skipping this sample – invalid RMS"
    fi
  done

  if [[ ${#rms_values[@]} -eq 0 ]]; then
    dbg "DEBUG: no finite RMS readings – unable to analyze dynamic stereo"
    DYNAMIC_STEREO_RESULT="⚠️ Unable to test this file – please use Adobe Audition"
  else
    rms_lr=$(printf '%s\n' "${rms_values[@]}" | sort -n | tail -1)
    dbg "$(printf "DEBUG: selected RMS %.2f dB from %d valid samples" "$rms_lr" "${#rms_values[@]}")"
    rms_lr_fmt=$( awk -v x="$rms_lr" 'BEGIN{printf "%.1f", x}' )
    export rms_lr_fmt
    if awk "BEGIN{exit !($rms_lr > -50)}"; then
      DYNAMIC_STEREO_RESULT="✅ PASS"
    else
      DYNAMIC_STEREO_RESULT="❌ FAIL (RMS L-R too low: $rms_lr dB)"
    fi

    # Export human-friendly balance summary (fallback to L-R RMS magnitude if needed)
    if [[ -z "$best_diff_db" ]]; then
      # Derive a magnitude from L-R RMS as a fallback
      best_diff_db=$( awk -v x="$rms_lr" 'BEGIN{printf "%.1f", (x<0)?-x:x}' )
      best_label="$best_diff_db dB, Channel difference"
      best_dir_label="Channel difference"
    fi
    export balance_diff_db="$best_diff_db"
    export balance_label="$best_label"
    export balance_label_dir="${best_dir_label:-Channel difference}"
  fi
fi

step_end "Phase 2 Dynamic Stereo Test"

}

