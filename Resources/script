# --- Preflight: ensure Apple Command Line Tools (for /usr/bin/swift) ---
need_swift_dialogs=1
if [[ "$need_swift_dialogs" == 1 ]]; then
  have_clt() {
    # xcode-select returns a path when tools are present
    xcode-select -p &>/dev/null && return 0
    # fallback: look for the package receipt
    pkgutil --pkg-info com.apple.pkg.CLTools_Executables &>/dev/null
  }

  clt_silent_install() {
    echo "[PRE-FLIGHT] Attempting command-line install of Xcode Command Line Tools…"
    # Make CLT visible to softwareupdate
    sudo touch /tmp/.com.apple.dt.CommandLineTools.installondemand.in-progress
    # Grab the first matching label
    local PROD
    PROD=$(softwareupdate -l 2>/dev/null \
           | grep -E "\*.*Command Line.*Tools" \
           | head -n 1 | awk -F"*" '{print $2}' \
           | sed -e 's/^ *//' | tr -d '\n')
    if [[ -n "$PROD" ]]; then
      sudo softwareupdate -i "$PROD" --verbose || return 1
      sudo xcode-select --switch /Library/Developer/CommandLineTools || return 1
      echo "[PRE-FLIGHT] CLT installed. Please relaunch this app once install finishes."
    else
      echo "[PRE-FLIGHT] Could not find a CLT package label in Software Update." >&2
      return 1
    fi
    sudo rm -f /tmp/.com.apple.dt.CommandLineTools.installondemand.in-progress
  }

  # If CLT missing, try to install or prompt user
  if ! have_clt; then
    echo "[PRE-FLIGHT] Apple Command Line Tools not found."
    if command -v swift >/dev/null 2>&1; then
      echo "[PRE-FLIGHT] 'swift' exists, proceeding anyway."
    else
      if [[ $EUID -ne 0 ]]; then
        echo "[PRE-FLIGHT] Launching Apple's installer dialog…"
        /usr/bin/xcode-select --install || true
        echo "[PRE-FLIGHT] Please complete the installation, then re‑run this app."
        exit 1
      else
        if command -v softwareupdate >/dev/null 2>&1; then
          clt_silent_install || {
            echo "[PRE-FLIGHT] Silent install failed. Please run without sudo to get the GUI installer." >&2
            exit 1
          }
          exit 1
        else
          echo "[PRE-FLIGHT] 'softwareupdate' not available. Please run without sudo to trigger the GUI installer." >&2
          /usr/bin/xcode-select --install || true
          exit 1
        fi
      fi
    fi
  else
    clt_path=$(xcode-select -p 2>/dev/null || echo "unknown")
    echo "[PRE-FLIGHT] CLT OK (${clt_path})"
    swift_path=$(command -v swift 2>/dev/null || echo "swift not found")
    echo "[PRE-FLIGHT] swift: ${swift_path}"
  fi
fi

