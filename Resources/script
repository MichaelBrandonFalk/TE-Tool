  local tc_str
  tc_str=$("$FFPROBE_BIN" -v error -print_format json -show_entries stream_tags=timecode "$FILE" | \
            grep -o '"timecode": *"[^"]*"' | head -n1 | sed -E 's/.*"([^"]+)".*/\1/')

  if [[ -z "$tc_str" ]]; then
    TIMECODE_FORMAT_RESULT="❌ FAIL (No timecode found)"
  elif [[ "$tc_str" =~ ";" || "$tc_str" =~ "," ]]; then
    TIMECODE_FORMAT_RESULT="✅ PASS (Drop-frame: $tc_str)"
  else
    TIMECODE_FORMAT_RESULT="❌ FAIL (Non-drop-frame: $tc_str)"
  fi
}



check_video_segment_times() {
  local start_times names durations count i name s d in_tc out_tc duration_sec markers_out

  # Grab ExifTool paths and ensure EXIFTOOL_BIN is set
  : "${EXIFTOOL_BIN:=exiftool}"



  # Get comma-separated lists (no whitespace)
  start_times=$("$EXIFTOOL_BIN" -s -s -s -TracksMarkersStartTime "$FILE" | tr -d ' ')
  names=$("$EXIFTOOL_BIN" -s -s -s -TracksMarkersName "$FILE" | sed 's/, /,/g')
  durations=$("$EXIFTOOL_BIN" -s -s -s -TracksMarkersDuration "$FILE" | tr -d ' ')

  # Convert to arrays
  IFS=',' read -ra starts <<< "$start_times"
  IFS=',' read -ra titles <<< "$names"
  IFS=',' read -ra lens <<< "$durations"
  count=${#starts[@]}
  markers_out="    Name       | In Time     | Out Time    | Duration (s)\n"
  markers_out+="    -----------+-------------+-------------+--------------\n"

  # Drop-frame converter
  frames_to_dropframe() {
    local frames=$1
    local fps=30
    local d=2
    local total_minutes=$((frames / (fps * 60)))
    local drop_frames=$((d * (total_minutes - (total_minutes / 10))))
    local tc_frames=$((frames + drop_frames))
    local hh=$((tc_frames / (fps * 60 * 60)))
    local mm=$(( (tc_frames / (fps * 60)) % 60 ))
    local ss=$(( (tc_frames / fps) % 60 ))
    local ff=$((tc_frames % fps))
    printf "%02d:%02d:%02d;%02d" "$hh" "$mm" "$ss" "$ff"
  }

  for ((i=0; i<count; i++)); do
    name="${titles[i]}"
    s="${starts[i]}"
    d="${lens[i]}"
    # Calculate timecodes and duration in seconds
    in_tc=$(frames_to_dropframe "$s")
    out_tc=""
    duration_sec=""
    if [[ -n "$d" ]]; then
      out_tc=$(frames_to_dropframe "$((s + d))")
      duration_sec=$((d / 30))
    else
      out_tc="--"
      duration_sec="--"
    fi
    # Table row, padded columns
    markers_out+="    $(printf '%-10s | %-11s | %-11s | %-6s' "$name" "$in_tc" "$out_tc" "$duration_sec")\n"
  done

  if [[ $count -gt 0 ]]; then
    VIDEO_MARKERS_RESULT="Markers found by ExifTool:"
    VIDEO_MARKERS_TIMES="$markers_out"
  else
    VIDEO_MARKERS_RESULT="No markers found by ExifTool"
    VIDEO_MARKERS_TIMES=""
  fi
}

