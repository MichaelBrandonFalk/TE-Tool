# -------- step timing helpers (Bash 3.2 safe) --------
step_key() { echo "${1//[^A-Za-z0-9_]/_}"; }  # scrub label → var-safe key

step_start() {
  local key; key=$(step_key "$1")
  eval "_STEP_${key}=$(date +%s)"
}

step_end() {
  local key start now elapsed
  key=$(step_key "$1")
  eval "start=\${_STEP_${key}:-}"
  if [[ -z $start ]]; then
    echo "step_end: unknown step '$1'" >&2
    return 1
  fi
  now=$(date +%s)
  elapsed=$(( now - start ))
  if [[ "$TE_VERBOSE" == "1" ]]; then
  printf '%-25s %02d:%02d:%02d\n' "$1 finished in" \
         $((elapsed/3600)) $(((elapsed%3600)/60)) $((elapsed%60))
fi
}

