#### Helper Seconds to Timcode for the end

seconds_to_tc() {                 # $1 seconds  $2 fps  $3 drop? (0/1)
  local s="$1" fps="$2" df="$3"
  local total_frames
  total_frames=$(awk -v sec="$s" -v fps="$fps" 'BEGIN{printf "%.0f", sec*fps}')
  if (( df )); then
    # add dropped frames back to get DF code (NTSC constant-based)
    local d=$((2 * (total_frames / 17982) ))   # 17982 = 10 min * 29.97 * 60
    total_frames=$(( total_frames + d + 2*((total_frames - d)/1800 - (total_frames - d)/17982) ))
  fi
  # Use an integer fps for integer arithmetic below
  local fps_int
  fps_int=$(awk -v f="$fps" 'BEGIN{printf "%.0f", f}')
  [[ -z "$fps_int" || "$fps_int" -le 0 ]] && fps_int=30

  local hh=$(( total_frames / (3600*fps_int) ))
  local mm=$(( (total_frames / (60*fps_int)) % 60 ))
  local ss=$(( (total_frames / fps_int) % 60 ))
  local ff=$(( total_frames % fps_int ))
  local sep=":"
  (( df )) && sep=";"
  printf "%02d:%02d:%02d%s%02d" "$hh" "$mm" "$ss" "$sep" "$ff"
}


###############################################################################
# Helper – convert a time‑code string (HH:MM:SS;FF or HH:MM:SS:FF) to seconds
#          (we ignore the frame component for second‑level accuracy)
###############################################################################
###############################################################################
# SMPTE → seconds  (handles 29.97 drop-frame when ‘;’ present)
# $1 = time-code string  HH:MM:SS;FF  or HH:MM:SS:FF
# $2 = nominal fps      (e.g. 29.97, 30, 23.98)  –  defaults to 29.97
###############################################################################








timecode_to_seconds() {
    local tc="$1" fps="${2:-29.97}"
    local drop=0
    [[ $tc == *";"* ]] && drop=1          # semicolon → drop-frame

    # Split TC into parts, tolerate missing frame field
    IFS=':;,' read -r hh mm ss ff <<< "$tc"
    ff=${ff:-0}
    hh=$((10#$hh)); mm=$((10#$mm)); ss=$((10#$ss)); ff=$((10#$ff))

    if (( drop )) && [[ $fps == 29.97* ]]; then
        # SMPTE drop-frame algorithm (NTSC only)
        # Total minutes since 00:00
        local tot_min=$((hh*60 + mm))
        # 2 frames dropped per minute, except every 10th
        local drop_frames=$((2 * (tot_min - tot_min/10)))
        local frames=$(( (hh*3600 + mm*60 + ss)*30 + ff - drop_frames ))
        awk -v f="$frames" 'BEGIN{printf "%.3f", f/29.97}'
    else
        # Non-drop or non-29.97
        local fps_int=$(awk -v f="$fps" 'BEGIN{printf "%.0f", f}')
        local frames=$(( (hh*3600 + mm*60 + ss)*fps_int + ff ))
        awk -v f="$frames" -v fps="$fps" 'BEGIN{printf "%.3f", f/fps}'
    fi
}
###############################################################################
# Helper – first 01:00:00:00 frame (or ;00) within first 120 s
#   • Returns seconds-offset (int) if a suitable header is found
#   • Returns nothing + exit-code 1 when header is missing / too far away
###############################################################################
find_first_zero_timecode_sec() {
    local f="$1"

    # ---------- 0) quick tag probe -----------------------------------------
    local tc first_tc=""
    tc=$("$FFPROBE_BIN" -v error -show_entries format_tags=timecode \
        -of default=nw=1:nk=1 "$f" | head -n1)
   dbg "[DEBUG] format-tag timecode='${tc:-NONE}'"
    [[ -n $tc ]] && first_tc="$tc"
    if [[ $tc == 01:00:00:00 || $tc == 01:00:00\;00 ]]; then printf '0\n'; return 0; fi


    tc=$("$FFPROBE_BIN" -v error -show_entries stream_tags=timecode \
        -of default=nw=1:nk=1 "$f" | head -n1)
  dbg "[DEBUG] stream-tag timecode='${tc:-NONE}'"
    [[ -z $first_tc ]] && first_tc="$tc"
    if [[ $tc == 01:00:00:00 || $tc == 01:00:00\;00 ]]; then printf '0\n'; return 0; fi

    # ---------- 1) offset from tag if within ±120 s ------------------------
    if [[ -n $first_tc && $first_tc != NONE ]]; then
        local fps_for_tc=${FRAME_RATE:-29.97}         # clip fps or default DF
        local target_tc
        [[ $first_tc == *";"* ]] && target_tc="01:00:00;00" || target_tc="01:00:00:00"

        local current_seconds target_seconds
        current_seconds=$(timecode_to_seconds "$first_tc"  "$fps_for_tc")
        target_seconds=$(timecode_to_seconds "$target_tc" "$fps_for_tc")

        local current_int=${current_seconds%%.*}
        local target_int=${target_seconds%%.*}
        local offset=$(( target_int - current_int ))

        if (( offset >= -120 && offset <= 120 )); then
            (( offset < 0 )) && offset=0
            dbg "[DEBUG] first tag '$first_tc' – using offset ${offset}s to reach $target_tc"
            printf '%d\n' "$offset"
            return 0
        fi
       dbg "[DEBUG] offset ${offset}s is outside ±120 s window – ignore header"
    fi

    # ---------- 2) frame-scan first 120 s ----------------------------------
    local pts tc_val
    while IFS=',' read -r pts tc_val _; do
        [[ -z $tc_val ]] && continue
        if [[ $tc_val == 01:00:00:00 || $tc_val == 01:00:00\;00 ]]; then
            printf '%s\n' "$pts"
            return 0
        fi
    done < <("$FFPROBE_BIN" -v error -select_streams v:0 -read_intervals "%+120" \
              -show_frames -show_entries frame=pkt_pts_time,pkt_timecode \
              -of csv=p=0 "$f")

    # ---------- 3) not found ----------------------------------------------
  
    return 1
}

