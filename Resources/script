 check_video_codec() {

      
 
  # Codec
  CODEC_TAG=$("$FFPROBE_BIN" -v error -select_streams v:0 \
      -show_entries stream=codec_tag_string \
      -of default=noprint_wrappers=1:nokey=1 "$FILE")
  if [[ "$CODEC_TAG" == "apch" ]]; then
      VIDEO_CODEC="ProRes 422 HQ"; VIDEO_CODEC_RESULT="✅ PASS"
  else
      VIDEO_CODEC="Unknown/Other"; VIDEO_CODEC_RESULT="❌ FAIL (expected ProRes 422 HQ)"
  fi
 }

 check_video_bitrate() {
  # Bit rate
  RAW_VBR=$(echo "$VIDEO_STREAM" | grep "^bit_rate=" | cut -d= -f2)
  if [[ "$RAW_VBR" =~ ^[0-9]+$ ]]; then
      VBR_MBPS=$(awk "BEGIN{printf \"%.1f\",$RAW_VBR/1000000}")
      if (( RAW_VBR >= 145000000 )); then
          VIDEO_BIT_RATE="HD – ${VBR_MBPS} Mb/s"; VIDEO_BIT_RATE_RESULT="✅ PASS"
      else
          VIDEO_BIT_RATE="${VBR_MBPS} Mb/s"; VIDEO_BIT_RATE_RESULT="❌ FAIL (below HD)"
      fi
  else
      VIDEO_BIT_RATE="N/A"; VIDEO_BIT_RATE_RESULT="❌ FAIL"
  fi
 }


check_resolution() {
  # Resolution
  WIDTH=$(echo "$VIDEO_STREAM" | grep "^width=" | cut -d= -f2)
  HEIGHT=$(echo "$VIDEO_STREAM" | grep "^height=" | cut -d= -f2)
  RESOLUTION="${WIDTH}x${HEIGHT}"
  if (( WIDTH == 1920 && HEIGHT == 1080 )); then
      RESOLUTION_RESULT="✅ PASS"
  else
      RESOLUTION_RESULT="❌ FAIL (below HD)"
  fi

}


check_aspect_ratio() {

  # Aspect ratio
  RAW_AR=$(echo "$VIDEO_STREAM" | grep "^display_aspect_ratio=" | cut -d= -f2)
