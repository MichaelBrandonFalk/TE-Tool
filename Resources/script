check_adv_chroma () {

  # Only run when selected
  if [[ "$ADVANCEDCHROMA_ON" != "1" ]]; then
    return
  fi

  step_start "Phase 2 Video - Chroma Excursion (native bit depth)"

  # --- detect pixel format and color range (tv/pc) -------------------------
  local PIX_FMT CR bits shift C_LOW C_HIGH
  PIX_FMT=$("$FFPROBE_BIN" -v error -select_streams v:0 \
             -show_entries stream=pix_fmt \
             -of default=nokey=1:noprint_wrappers=1 "$FILE")
  CR=$("$FFPROBE_BIN" -v error -select_streams v:0 \
         -show_entries stream=color_range \
         -of default=nokey=1:noprint_wrappers=1 "$FILE")

  # Normalize working format for filtergraph (drop alpha planes)
  local FMT="$PIX_FMT"
  if [[ $FMT == yuva* ]]; then
    FMT=${FMT/yuva/yuv}
  fi

  bits=8
  case "$PIX_FMT" in
    *p10*) bits=10 ;;
    *p12*) bits=12 ;;
  esac
  shift=$((bits - 8))

  # TV-legal chroma bounds scaled to bit depth
  (( C_LOW  = 16  << shift ))
  (( C_HIGH = 240 << shift ))

  # Optional border crop (disabled by default). Set ADVANCEDCHROMA_BORDER>0 to enable.
  local BORDER=${ADVANCEDCHROMA_BORDER:-0}
  local FILTER
  if (( BORDER > 0 )); then
    local CROP="crop=iw-2*${BORDER}:ih-2*${BORDER}:${BORDER}:${BORDER}"
    FILTER="format=${FMT},${CROP},signalstats,metadata=print:file=-"
  else
    FILTER="format=${FMT},signalstats,metadata=print:file=-"
  fi
 dbg "[ADV_CHROMA] PIX_FMT=$PIX_FMT FMT=$FMT bits=$bits shift=$shift CR=$CR BORDER=$BORDER"

  # --- measure U/V natively; do NOT insert format= before signalstats ------
  # This keeps subsampling and bit depth intact, matching QCTools behavior.
  local log
  log=$("$FFMPEG_BIN" -hide_banner -nostats -i "$FILE" -map 0:v:0 \
        -vf "$FILTER" -f null - 2>&1)

  # Accumulate global min/max for U and V across all frames
  local CB_MIN CB_MAX CR_MIN CR_MAX
  while IFS='=' read -r k v; do
    case "$k" in
      lavfi.signalstats.UMIN)
        [[ -z "$CB_MIN" || $v -lt $CB_MIN ]] && CB_MIN=$v ;;
      lavfi.signalstats.UMAX)
        [[ -z "$CB_MAX" || $v -gt $CB_MAX ]] && CB_MAX=$v ;;
      lavfi.signalstats.VMIN)
        [[ -z "$CR_MIN" || $v -lt $CR_MIN ]] && CR_MIN=$v ;;
      lavfi.signalstats.VMAX)
        [[ -z "$CR_MAX" || $v -gt $CR_MAX ]] && CR_MAX=$v ;;
    esac
  done < <(printf '%s\n' "$log" | grep -E 'lavfi\.signalstats\.(UMIN|UMAX|VMIN|VMAX)=')

  # Fallback if nothing parsed
  if [[ -z "$CB_MIN" || -z "$CB_MAX" || -z "$CR_MIN" || -z "$CR_MAX" ]]; then
    cb_min="N/A"; cb_max="N/A"; cr_min="N/A"; cr_max="N/A"
    cb_status="N/A"; cr_status="N/A"; chroma_warn=0
    step_end "Phase 2 Video - Chroma Excursion (native bit depth)"
    return
  fi

  # Export numeric values and 8-bit display equivalents
  cb_min=$CB_MIN; cb_max=$CB_MAX; cr_min=$CR_MIN; cr_max=$CR_MAX
  cb_min_8=$(( cb_min >> shift )); cb_max_8=$(( cb_max >> shift ))
  cr_min_8=$(( cr_min >> shift )); cr_max_8=$(( cr_max >> shift ))

  # Evaluate against TV-legal only for limited range; label full-range as info
  cb_status="✅ PASS"; cr_status="✅ PASS"; chroma_warn=0
  if [[ "$CR" == "pc" ]]; then
    cb_status="ℹ️ full-range"; cr_status="ℹ️ full-range"
  else
    if (( cb_min < C_LOW || cb_max > C_HIGH )); then cb_status="❌ FAIL"; chroma_warn=1; fi
    if (( cr_min < C_LOW || cr_max > C_HIGH )); then cr_status="❌ FAIL"; chroma_warn=1; fi
  fi

  # Preformatted lines for Results section (raw code values + 8-bit approx)
  printf -v CB_LINE "  U (Cb): min = %s (≈%s), max = %s (≈%s)    → %s" \
          "$cb_min" "$cb_min_8" "$cb_max" "$cb_max_8" "$cb_status"
  printf -v CR_LINE "  V (Cr): min = %s (≈%s), max = %s (≈%s)    → %s" \
          "$cr_min" "$cr_min_8" "$cr_max" "$cr_max_8" "$cr_status"
  export CB_LINE CR_LINE chroma_warn cb_status cr_status cb_min cr_min cb_max cr_max

  step_end "Phase 2 Video - Chroma Excursion (native bit depth)"
}


