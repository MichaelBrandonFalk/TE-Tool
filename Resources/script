    PIX_FMT=$("$FFPROBE_BIN" -v error -select_streams v:0 -show_entries stream=pix_fmt -of csv=p=0 "$FILE")
    COLOR_RANGE=$("$FFPROBE_BIN" -v error -select_streams v:0 -show_entries stream=color_range -of csv=p=0 "$FILE")

    FULL_RANGE=0
    [[ $COLOR_RANGE == pc || $PIX_FMT == yuvj* ]] && FULL_RANGE=1

    if (( FULL_RANGE )); then
        case $PIX_FMT in
            *p12*) BLACK=0 WHITE=4095 ;;
            *p10*) BLACK=0 WHITE=1023 ;;
                 *) BLACK=0 WHITE=255  ;;
        esac
    else
        case $PIX_FMT in
            *p12*) BLACK=256 WHITE=3760 ;;
            *p10*) BLACK=64  WHITE=940  ;;
                 *) BLACK=16  WHITE=235  ;;
        esac
    fi
    RANGE=$(( WHITE - BLACK ))
    DIV=1

    # ── 2) frame-sampling cadence ──────────────────────────────────────────
    frame_step=24   # ≈0.5 s

    # ── 3) build lavfi chain ───────────────────────────────────────────────
    if [[ $TEST_TYPE == "Broadcast Master" ]]; then
        zero_timecode_sec=$(find_first_zero_timecode_sec "$FILE")
        base_offset=${zero_timecode_sec:-0}
        
        if [[ -z $zero_timecode_sec ]]; then
    ##echo "[WARN] No 01:00:00:00 TC in first 2 min – running IRE from t=0" >&2
    base_offset=0
    tc_warning="⚠️  (No 01:00:00:00 TC in first 2 min– running IRE from t=0 )"
    lavfi="movie=${FILE},select='not(mod(n\\,${frame_step}))',signalstats"
else
    base_offset=${zero_timecode_sec}
    tc_warning=""
    lavfi="movie=${FILE},select='gte(t\\,${zero_timecode_sec})*not(mod(n\\,${frame_step}))',signalstats"
fi
    else
        lavfi="movie=${FILE},select='not(mod(n\\,${frame_step}))',signalstats"
    fi

    # ── 4) run signalstats & collect extremes (+ frame index) ──────────────
    read -r min_luma max_luma min_idx max_idx <<< \
      $("${FFPROBE_BIN}" -v error -threads 0 -f lavfi -i "$lavfi" \
         -show_entries frame_tags=lavfi.signalstats.YMIN,lavfi.signalstats.YMAX \
         -of csv=p=0 |
        awk -F',' -v div="$DIV" '
            BEGIN{min=65535; max=0; idx=0; min_i=-1; max_i=-1}
            NF==2 && $1!="" && $2!="" {
                y1=int($1/div); y2=int($2/div)
                if (y1<min){min=y1; min_i=idx}
                if (y2<min){min=y2; min_i=idx}
                if (y1>max){max=y1; max_i=idx}
                if (y2>max){max=y2; max_i=idx}
                idx++
            }
            END{print min,max,min_i,max_i}')

    # ── Fallback: if no frames passed after offset, retrying IRE scan from t=0 ───────
    if [[ $min_idx -lt 0 ]]; then
        dbg "[DEBUG] No frames after offset – retrying IRE scan from t=0"
         # Reset base_offset since we're starting from beginning
        base_offset=0
        tc_warning="⚠️ (restarted from t=0 - no frames found after timecode offset)"
        
        lavfi="movie=${FILE},select='not(mod(n\\,${frame_step}))',signalstats"

        read -r min_luma max_luma min_idx max_idx <<< \
          $("${FFPROBE_BIN}" -v error -threads 0 -f lavfi -i "$lavfi" \
             -show_entries frame_tags=lavfi.signalstats.YMIN,lavfi.signalstats.YMAX \
             -of csv=p=0 |
            awk -F',' -v div="$DIV" '
                BEGIN{min=65535; max=0; idx=0; min_i=-1; max_i=-1}
                NF==2 && $1!="" && $2!="" {
                    y1=int($1/div); y2=int($2/div)
                    if (y1<min){min=y1; min_i=idx}
                    if (y2<min){min=y2; min_i=idx}
                    if (y1>max){max=y1; max_i=idx}
                    if (y2>max){max=y2; max_i=idx}
                    idx++
                }
                END{print min,max,min_i,max_i}')
    fi

    # ── 5) convert to IRE & verdict ────────────────────────────────────────
    if [[ -n $min_luma && -n $max_luma && $RANGE -ne 0 ]]; then




# Sanity checks
        if [[ $min_luma -lt 0 ]]; then
            dbg "[WARN] min_luma ($min_luma) is negative - unusual!"
        fi
        if [[ $min_luma -lt $BLACK ]]; then
            dbg "[WARN] min_luma ($min_luma) below BLACK level ($BLACK) - indicates sub-black"
        fi
        if [[ $max_luma -gt $WHITE ]]; then
            dbg "[WARN] max_luma ($max_luma) above WHITE level ($WHITE) - indicates super-white"
        fi

        # Show the actual calculation
        dbg "[DEBUG] Min IRE calc: ($min_luma - $BLACK) * 100 / $RANGE"
        dbg "[DEBUG] Max IRE calc: ($max_luma - $BLACK) * 100 / $RANGE"

        LUMA_MIN_IRE=$(awk -v m="$min_luma" -v B="$BLACK" -v R="$RANGE" 'BEGIN{printf "%.2f", (m-B)*100/R}')
        LUMA_MAX_IRE=$(awk -v m="$max_luma" -v B="$BLACK" -v R="$RANGE" 'BEGIN{printf "%.2f", (m-B)*100/R}')

        dbg "[DEBUG] Calculated IRE: min=$LUMA_MIN_IRE, max=$LUMA_MAX_IRE"
        dbg "[DEBUG] ============================================="

        pass_low=$(echo "$LUMA_MIN_IRE < -1" | bc)
        pass_high=$(echo "$LUMA_MAX_IRE > 101" | bc)

        dbg "[DEBUG] Threshold check: pass_low=$pass_low, pass_high=$pass_high"

        if (( pass_low || pass_high )); then
            LUMA_RANGE_RESULT="⚠️ WARNING"
        else
            LUMA_RANGE_RESULT="✅ PASS"
        fi
        LUMA_LOC_MIN=$min_idx
        LUMA_LOC_MAX=$max_idx
        # --- sample‑index → HH:MM:SS.ss (now accounts for base_offset) -------
        # Resolve fps as a float (default 30) without invoking awk twice
        fps_num=${FRAME_RATE:-30}
        idx_to_ts() {                                  # $1 = index
            local idx="$1"
            local base_off="$2"  # Pass base_offset as parameter
            
            # seconds = (index * step / fps) + base_offset
            local sec
            sec=$(awk -v i="$idx" -v st="$frame_step" -v f="$fps_num" -v base="$base_offset" \
                'BEGIN{printf "%.2f", i*st/f + base}')
            
            # For reporting, output SMPTE time-code instead of a decimal-seconds string
    local df=0
    [[ $FRAME_RATE == 29.97* && $first_tc == *";"* ]] && df=1   # drop-frame?
    seconds_to_tc "$sec" "$fps_num" "$df"                       # << returns HH:MM:SS;FF or :
}
         # Pass base_offset to timestamp calculation
        LUMA_LOC_MIN_TS=$(idx_to_ts "$LUMA_LOC_MIN" "$base_offset")
        LUMA_LOC_MAX_TS=$(idx_to_ts "$LUMA_LOC_MAX" "$base_offset")
    else
        LUMA_MIN_IRE="N/A"; LUMA_MAX_IRE="N/A"; LUMA_RANGE_RESULT="ERROR"
        LUMA_LOC_MIN_TS=""
        LUMA_LOC_MAX_TS=""
    fi

if [[ -n $tc_warning ]]; then
    LUMA_RANGE_RESULT="$LUMA_RANGE_RESULT $tc_warning"
fi


    # ── 6) export summary fields ───────────────────────────────────────────
    export LUMA_MIN="$LUMA_MIN_IRE"  LUMA_MAX="$LUMA_MAX_IRE"  LUMA_RESULT="$LUMA_RANGE_RESULT" \
           LUMA_LOC_MIN LUMA_LOC_MAX LUMA_LOC_MIN_TS LUMA_LOC_MAX_TS
    export luma_min_ire="$LUMA_MIN_IRE" luma_max_ire="$LUMA_MAX_IRE"

    step_end "Phase 2 Video - Luma IRE"
}

