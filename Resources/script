check_dark_frame() {

step_start "Phase 2 Video - Head and Tail"

codec=$("$FFPROBE_BIN" -v error -select_streams v:0 \
        -show_entries stream=codec_name \
        -of default=noprint_wrappers=1:nokey=1 "$FILE")

case "$codec" in
  h264|hevc)          threshold=45 ;;
  prores*|dnxhd)      threshold=74 ;;
  *)                  threshold=40 ;;
esac


# ---- helper filter string ----------------------------------------------------
STAT_FILTER="signalstats,metadata=print:key=lavfi.signalstats.YAVG:file=-"

# ---- head probe --------------------------------------------------------------
first=$("$FFMPEG_BIN" -v error -i "$FILE" \
        -vf "$STAT_FILTER" -frames:v 1 -f null - 2>&1 |
        awk -F= '/lavfi.signalstats.YAVG/ {print $2; exit}')

# ---- tail probe (seek 50 ms before EOF) --------------------------------------
last=$("$FFMPEG_BIN" -v error -noaccurate_seek -sseof -0.05 -i "$FILE" \
       -vf "$STAT_FILTER" -frames:v 1 -f null - 2>&1 |
       awk -F= '/lavfi.signalstats.YAVG/ {print $2; exit}')

# ---- fallback safety defaults ------------------------------------------------
first=${first:-100}; last=${last:-100}
lte() { echo "$1 <= $2" | bc -l; }

first_dark=$(lte "$first" "$threshold")
last_dark=$(lte "$last" "$threshold")



if   (( first_dark &&  last_dark )); then
  DARK_FRAME_RESULT="✅ PASS"
  DARK_FRAME_MSG="Dark Frames: ✅ Present at head & tail"
elif (( !first_dark && last_dark )); then
  DARK_FRAME_RESULT="❌ FAIL"
  DARK_FRAME_MSG="Dark Frames: ❌ Missing head"
elif (( first_dark && !last_dark )); then
  DARK_FRAME_RESULT="❌ FAIL"
  DARK_FRAME_MSG="Dark Frames: ❌ Missing tail"
else
  DARK_FRAME_RESULT="❌ FAIL"
  DARK_FRAME_MSG="Dark Frames: ❌ Missing head & tail"
fi

step_end "Phase 2 Video - Head and Tail"

dbg "[TRACE] about to test LUMAIRE_ON = '$LUMAIRE_ON'"
}


