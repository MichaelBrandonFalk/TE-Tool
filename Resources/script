###############################################################################
# check_continuity: Video decode error and timestamp continuity check
# (Top-level definition so it exists before any calls)
###############################################################################
check_continuity() {
  local f="$FILE"
  local base_name
  base_name="$(basename "${f%.*}")"

  # Logs go to the global LOG_DIR with per-file prefixes
  local decode_log="$LOG_DIR/${base_name}_decode_errors.log"
  local cont_csv="$LOG_DIR/${base_name}_continuity.csv"
  : >"$decode_log"
  : >"$cont_csv"

  # 1) Decode error scan (catches corrupt frames/packets)
  #    Keep stderr at error level only and record to decode_log
  "$FFMPEG_BIN" -v error -xerror -nostdin -i "$f" -f null - 2>>"$decode_log"

  # 2) Determine FPS and expected step size
  local fps step
  fps=$("$FFPROBE_BIN" -v error -select_streams v:0 \
        -show_entries stream=r_frame_rate -of csv=p=0 "$f" | \
        awk -F/ '{if($2==0||$2==""||$1=="") print 0; else printf "%.6f", $1/$2}')
  if [[ -z "$fps" || "$fps" == "0.000000" || "$fps" == 0 ]]; then
    CONTINUITY_RESULT="❌ FAIL"
    CONTINUITY_MSG="Continuity: Unable to determine FPS"
    return
  fi
  step=$(awk -v x="$fps" 'BEGIN{printf "%.9f", 1.0/x}')

  # 3) Frame timestamp scan for gaps (>1.5*step) and regressions (<-0.5ms)
  # Write CSV header
  echo "type,video_time(HH:MM:SS.mmm),delta_s,expected_step_s,fps" >>"$cont_csv"

  # Collect best_effort_timestamp_time list
  local tmp_pts; tmp_pts=$(mktemp)
  "$FFPROBE_BIN" -v error -select_streams v:0 -show_frames \
    -show_entries frame=best_effort_timestamp_time -of csv=p=0 "$f" \
    | awk -F, '$1 ~ /^frame/ && $2 != "N/A" {print $2}' >"$tmp_pts"

  local gaps=0 regs=0 first_ts="" first_type=""
  awk -v step="$step" '
    function fmt(s){ h=int(s/3600); s-=h*3600; m=int(s/60); s-=m*60; ms=int((s-int(s))*1000+0.5); printf("%02d:%02d:%02d.%03d",h,m,int(s),ms) }
    NR==1 {prev=$0; next}
    { d=$0-prev; if (d < -0.0005) { regs++; if (first=="") {first=$0; ft="REGRESSION"} } else if (d > 1.5*step) { gaps++; if (first=="") {first=$0; ft="GAP"} } prev=$0 }
    END { if (first!="") printf("%d %d %.6f %s\n", gaps, regs, first, ft); else printf("%d %d 0 CLEAN\n", gaps, regs) }
  ' "$tmp_pts" >"$tmp_pts.out"

  local gaps_count regs_count first_val first_lbl
  read -r gaps_count regs_count first_val first_lbl <"$tmp_pts.out"
  rm -f "$tmp_pts" "$tmp_pts.out"

  # Pretty time
  local first_hms=""
  if [[ -n "$first_val" && "$first_val" != "0" ]]; then
    first_hms=$(awk -v s="$first_val" 'BEGIN{h=int(s/3600); s-=h*3600; m=int(s/60); s-=m*60; ms=int((s-int(s))*1000+0.5); printf("%02d:%02d:%02d.%03d",h,m,int(s),ms)}')
  fi

  # Count decode errors (lines in decode_log)
  local dec_errs=0
  [[ -s "$decode_log" ]] && dec_errs=$(wc -l <"$decode_log" | tr -d ' ')

  # Verdict → message
  local verdict
  if (( dec_errs > 0 || regs_count > 0 )); then
    verdict="❌ FAIL"
  elif (( gaps_count > 0 )); then
    verdict="⚠️ WARNING"
  else
    verdict="✅ PASS"
  fi

  if [[ -n "$first_hms" ]]; then
    CONTINUITY_MSG="${verdict} (decode errors: ${dec_errs}; gaps: ${gaps_count}; regressions: ${regs_count}) – first issue at ${first_hms}"
  else
    CONTINUITY_MSG="${verdict} (decode errors: ${dec_errs}; gaps: ${gaps_count}; regressions: ${regs_count})"
  fi
}
check_iframe() {
  local f="$1"

  # fast packet-flag scan
  local total keypkts
  total=$("$FFPROBE_BIN" -v error -select_streams v:0 \
          -show_entries packet=flags -of csv=p=0 "$f" | wc -l)
  keypkts=$("$FFPROBE_BIN" -v error -select_streams v:0 \
            -show_entries packet=flags -of csv=p=0 "$f" | grep -c K)

  if [[ $total -eq $keypkts && $total -ne 0 ]]; then
    # slice-header verify on first 5 000 frames
    if "$FFPROBE_BIN" -v error -select_streams v:0 -read_intervals "%+#5000" \
         -show_frames -show_entries frame=pict_type -of csv=p=0 "$f" |
         grep -m1 -E 'P|B' >/dev/null ; then
      FRAME_TYPE_RESULT="❌ FAIL"
      FRAME_TYPE_MSG="Frame Type : Non-I packets detected"
    else
      FRAME_TYPE_RESULT="✅ PASS"
      FRAME_TYPE_MSG="Frame Type : I-Frame Only packets"
    fi
  else
    FRAME_TYPE_RESULT="❌ FAIL"
    FRAME_TYPE_MSG="Frame Type : Non-I packets detected"
  fi
}




